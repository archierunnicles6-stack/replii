{
  "name": "ghost-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Ghost — live AI meeting assistant overlay",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/prepare-dev-app.mjs && node scripts/dev.mjs",
    "dev:raw": "electron-vite dev",
    "open-app": "node scripts/open-ghost-app.mjs",
    "open-app:dev": "node scripts/open-ghost-app.mjs --dev",
    "setup:blackhole": "node scripts/setup-blackhole.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icons": "python3 scripts/generate-app-icon.py",
    "package": "node scripts/ensure-icon.mjs && npm run build && electron-builder --mac --dir",
    "package:mac": "node scripts/prepare-ci-build.mjs && node scripts/ensure-icon.mjs && npm run build && electron-builder --mac",
    "package:win": "node scripts/prepare-ci-build.mjs && node scripts/ensure-icon.mjs && npm run build && electron-builder --win",
    "fix:installed": "node scripts/sign-mac-app.mjs /Applications/Ghost.app",
    "test:audio": "node scripts/test-audio-suggestions.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.ghost.app",
    "productName": "Ghost",
    "afterPack": "./scripts/after-pack.mjs",
    "win": {
      "icon": "build/icon.png",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Ghost-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ghost",
      "installerIcon": "build/icon.png",
      "uninstallerIcon": "build/icon.png",
      "installerHeaderIcon": "build/icon.png"
    },
    "mac": {
      "artifactName": "Ghost.${ext}",
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Ghost needs microphone access to transcribe your voice during sales calls.",
        "NSScreenCaptureDescription": "Ghost uses Screen Recording to capture call audio from Zoom, Meet, or Teams. Ghost does not view or record your screen."
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Ghost",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 360,
          "type": "file",
          "path": "build/Install Ghost.command"
        },
        {
          "x": 410,
          "y": 360,
          "type": "file",
          "path": "build/Open Ghost.command"
        }
      ]
    },
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": ".env",
        "to": ".env",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "files": [
      "out/**/*"
    ]
  }
}

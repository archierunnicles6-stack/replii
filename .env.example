# OpenAI (required for /overlay demo and API routes)
OPENAI_API_KEY=

# Supabase (client + server)
# service_role must be from the SAME project as SUPABASE_URL / NEXT_PUBLIC_SUPABASE_URL
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_APP_URL=https://ghost.ai

# Stripe (server-only — /api/stripe/*)
# 1. Create products & recurring prices in Stripe Dashboard (test mode first):
#    - Pro monthly ($20/mo), Pro annual ($136.99/yr)
# 2. Copy each price ID (price_...) into the vars below.
# 3. Webhooks: Dashboard → Developers → Webhooks → Add endpoint
#    URL: https://your-domain.com/api/stripe/webhook
#    Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
#    Local dev: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_ANNUAL=

# Set to true to enable mock audio in web demo (default on in dev)
NEXT_PUBLIC_MOCK_AUDIO=true

# Vite / desktop app (copy from above where noted)
VITE_OPENAI_API_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_USE_MOCK_AUDIO=true
VITE_LEGAL_BASE_URL=https://ghost.ai
# Point at your Next.js server (use http://localhost:3000 for local billing tests)
VITE_API_BASE_URL=https://ghost.ai
VITE_GOOGLE_CLIENT_ID=

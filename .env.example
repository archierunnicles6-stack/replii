# OpenAI (required for /overlay demo and API routes)
OPENAI_API_KEY=

# Supabase (client + server)
# service_role must be from the SAME project as SUPABASE_URL / NEXT_PUBLIC_SUPABASE_URL
# Apply migrations once after linking: supabase login && supabase db push
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://replii-lac.vercel.app
NEXT_PUBLIC_SITE_URL=https://replii.ai

# Stripe (server-only — /api/stripe/*)
# Products (test mode):
#   Pro monthly — prod_UjdHAQ1ehL5fAk → STRIPE_PRICE_PRO
#   Pro annual  — prod_UjdKZ8yrbp1oFR → STRIPE_PRICE_PRO_ANNUAL
# Webhooks: Dashboard → Developers → Webhooks → Add endpoint
#   URL: https://replii-lac.vercel.app/api/webhooks/stripe
#   (rewrites to /api/stripe/webhook)
#   Events: checkout.session.completed, invoice.paid, invoice.payment_failed,
#           customer.subscription.updated, customer.subscription.deleted
#   Local dev: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Pro monthly (prod_UjdHAQ1ehL5fAk)
STRIPE_PRODUCT_PRO_MONTHLY=prod_UjdHAQ1ehL5fAk
STRIPE_PRICE_PRO=price_1TkA1O2n3eKD6EW3pdZjl5cp
# Pro annual (prod_UjdKZ8yrbp1oFR)
STRIPE_PRODUCT_PRO_ANNUAL=prod_UjdKZ8yrbp1oFR
STRIPE_PRICE_PRO_ANNUAL=price_1TkA3U2n3eKD6EW3Js1EyWKu
# Optional — only needed if you add client-side Stripe.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Admin dashboard (server-only — /api/admin/*)
ADMIN_EMAIL=aarunnicles@gmail.com

# Desktop installer URLs (optional — defaults to GitHub Release latest assets)
# NEXT_PUBLIC_MAC_DOWNLOAD_URL=https://github.com/archierunnicles6-stack/replii/releases/latest/download/Replii.dmg
# NEXT_PUBLIC_WINDOWS_DOWNLOAD_URL=https://github.com/archierunnicles6-stack/replii/releases/latest/download/Replii-Setup.exe

# Vite / desktop app (copy from above where noted)
VITE_OPENAI_API_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_USE_MOCK_AUDIO=true
VITE_LEGAL_BASE_URL=https://replii.ai
# Point at your Next.js server (use http://localhost:3000 for local billing tests)
VITE_API_BASE_URL=https://replii-lac.vercel.app
VITE_GOOGLE_CLIENT_ID=821453006387-t40vuplgvemi57kf3qhqp9gca4qmicd5.apps.googleusercontent.com

